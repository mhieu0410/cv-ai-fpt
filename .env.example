# ──────────────────────────────────────────────────────────────
# CV AI FPT — Environment variables
# Sao chép file này thành `.env.local` rồi điền giá trị thật.
# ──────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service_role key — CHỈ dùng server-side, KHÔNG bao giờ expose ra client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Phân quyền admin: danh sách email, phân tách bằng dấu phẩy
ADMIN_EMAILS=admin@fpt.edu.vn,owner@example.com

# Gói & hạn mức
NEXT_PUBLIC_PRO_PRICE_VND=49000
NEXT_PUBLIC_FREE_CV_LIMIT=5

# Thông tin ngân hàng nhận thanh toán (hiển thị + sinh VietQR)
NEXT_PUBLIC_BANK_BIN=970415
NEXT_PUBLIC_BANK_NAME=Vietinbank
NEXT_PUBLIC_BANK_ACCOUNT=106876557450
NEXT_PUBLIC_BANK_HOLDER=CAO MINH HIEU

# Dịch vụ AI đối chiếu CV ↔ JD.
# Để trống hoặc 'mock' để dùng kết quả giả lập khi phát triển.
AI_MATCH_API_URL=mock

# (Tuỳ chọn) URL công khai của site — dùng cho metadata/SEO (Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dịch vụ AI gợi ý việc & phân tích độ khớp (job matching)
JOB_RECOMMEND_API_URL=https://your-job-search.vercel.app/api/recommend
JOB_ANALYZE_API_URL=https://your-job-search.vercel.app/api/analyze-job
